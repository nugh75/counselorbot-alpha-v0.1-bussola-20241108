# === PROVIDER ===
# Scegli il provider: openai | openrouter | groq | togetherai | deepseek
LLM_PROVIDER=openai

# === CHIAVI API ===
# Solo quella del provider scelto deve essere valorizzata; lascia le altre vuote.
OPENAI_API_KEY=sk-your-key-here
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHERAI_API_KEY=
DEEPSEEK_API_KEY=

# === MODELLO (opzionale) ===
# Se omesso, usa il default del provider:
#   openai:    gpt-4o-mini
#   openrouter: meta-llama/llama-3.2-3b-instruct:free
#   groq:      llama3-8b-8192
#   togetherai: mistralai/Mixtral-8x7B-Instruct-v0.1
#   deepseek:  deepseek-chat
# Scommenta la riga corrispondente per sovrascrivere:
# OPENAI_MODEL=
# OPENROUTER_MODEL=
# GROQ_MODEL=
# TOGETHERAI_MODEL=
# DEEPSEEK_MODEL=
